 score_* cols for Macro & Meso\n","# ════════════════════════════════════════════════════════════════════\n","\n","import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","import os\n","\n","SCORES_DIR = '/content/drive/MyDrive/MasterThesis_Archetypes/03_ArchetypalScores'\n","OUTPUT_DIR = '/content/drive/MyDrive/MasterThesis_Archetypes/04_AnalysisOutputs'\n","VIZ_DIR    = '/content/drive/MyDrive/MasterThesis_Archetypes/05_Visualizations'\n","\n","ARCHETYPE_ORDER = ['Shadow', 'Hero', 'Wise_Mentor', 'Victim', 'Trickster',\n","                   'Great_Mother', 'Anima', 'Animus', 'Self']\n","ARCH_COLORS = {\n","    'Shadow': '#2d2d2d', 'Hero': '#c0392b', 'Wise_Mentor': '#2980b9',\n","    'Victim': '#8e44ad', 'Trickster': '#e67e22', 'Great_Mother': '#27ae60',\n","    'Anima': '#f39c12', 'Animus': '#16a085', 'Self': '#7f8c8d'\n","}\n","SCORE_COLS = [f'score_{a}' for a in ARCHETYPE_ORDER]\n","\n","# ── LOAD ─────────────────────────────────────────────────────────────\n","df_macro = pd.read_csv(f'{SCORES_DIR}/macro_archetype_scores.csv')\n","df_meso  = pd.read_csv(f'{SCORES_DIR}/meso_archetype_scores_FULL.csv')\n","df_micro = pd.read_csv(f'{SCORES_DIR}/micro_NB5_handoff.csv')\n","\n","# ── DERIVE Dominant_Archetype FROM score_* COLUMNS ──────────────────\n","# Macro: score_Shadow, score_Hero, etc. → pick highest per row\n","df_macro['Dominant_Archetype'] = (\n","    df_macro[SCORE_COLS].idxmax(axis=1).str.replace('score_', '', regex=False)\n",")\n","df_macro['Archetype_Score'] = df_macro[SCORE_COLS].max(axis=1)\n","\n","# Meso: same logic using score_* cols (raw scores, not rel_*)\n","df_meso['Dominant_Archetype'] = (\n","    df_meso[SCORE_COLS].idxmax(axis=1).str.replace('score_', '', regex=False)\n",")\n","df_meso['Archetype_Score'] = df_meso[SCORE_COLS].max(axis=1)\n","\n","# Micro already has Dominant_Archetype — confirm\n","print(\"── DOMINANT ARCHETYPE DERIVED ───────────────────────────────────\")\n","print(f\"  Macro unique archetypes : {sorted(df_macro['Dominant_Archetype'].unique())}\")\n","print(f\"  Meso  unique archetypes : {sorted(df_meso['Dominant_Archetype'].unique())}\")\n","print(f\"  Micro unique archetypes : {sorted(df_micro['Dominant_Archetype'].unique())}\")\n","\n","# ── LEVEL DISTRIBUTIONS ──────────────────────────────────────────────\n","def arch_dist(df, label):\n","    counts = df['Dominant_Archetype'].value_counts()\n","    pct    = (counts / counts.sum() * 100).round(2)\n","    out    = pd.DataFrame({'n': counts, 'pct': pct})\n","    out.index.name = 'Archetype'\n","    out['Level'] = label\n","    return out.reset_index()\n","\n","dist_macro = arch_dist(df_macro, 'Macro')\n","dist_meso  = arch_dist(df_meso,  'Meso')\n","dist_micro = arch_dist(df_micro, 'Micro')\n","all_dist   = pd.concat([dist_macro, dist_meso, dist_micro], ignore_index=True)\n","all_dist.to_csv(f'{OUTPUT_DIR}/NB5_archetype_prevalence_by_level.csv', index=False)\n","\n","print(\"\\n── ARCHETYPE PREVALENCE BY LEVEL (%) ───────────────────────────\")\n","pivot = (all_dist.pivot(index='Archetype', columns='Level', values='pct')\n","                 .reindex(ARCHETYPE_ORDER).fillna(0))\n","print(pivot.round(2).to_string())\n","\n","# ── CONVERGENCE MATRIX ───────────────────────────────────────────────\n","rank_macro = (dist_macro.set_index('Archetype')['pct']\n","              .reindex(ARCHETYPE_ORDER).fillna(0)\n","              .rank(ascending=False).rename('Rank_Macro'))\n","rank_meso  = (dist_meso.set_index('Archetype')['pct']\n","              .reindex(ARCHETYPE_ORDER).fillna(0)\n","              .rank(ascending=False).rename('Rank_Meso'))\n","rank_micro = (dist_micro.set_index('Archetype')['pct']\n","              .reindex(ARCHETYPE_ORDER).fillna(0)\n","              .rank(ascending=False).rename('Rank_Micro'))\n","\n","conv = pd.concat([\n","    dist_macro.set_index('Archetype')['pct'].reindex(ARCHETYPE_ORDER).fillna(0).rename('Macro_pct'),\n","    dist_meso.set_index('Archetype')['pct'].reindex(ARCHETYPE_ORDER).fillna(0).rename('Meso_pct'),\n","    dist_micro.set_index('Archetype')['pct'].reindex(ARCHETYPE_ORDER).fillna(0).rename('Micro_pct'),\n","    rank_macro, rank_meso, rank_micro\n","], axis=1)\n","\n","conv['Mean_Rank']         = conv[['Rank_Macro','Rank_Meso','Rank_Micro']].mean(axis=1)\n","conv['Rank_Std']          = conv[['Rank_Macro','Rank_Meso','Rank_Micro']].std(axis=1)\n","conv['Convergence_Score'] = 1 / (conv['Rank_Std'] + 0.1)\n","conv = conv.sort_values('Mean_Rank')\n","conv.index.name = 'Archetype'\n","conv.to_csv(f'{OUTPUT_DIR}/NB5_crosslevel_convergence.csv')\n","\n","print(\"\\n── CROSS-LEVEL CONVERGENCE TABLE ───────────────────────────────\")\n","print(conv[['Macro_pct','Meso_pct','Micro_pct',\n","            'Rank_Macro','Rank_Meso','Rank_Micro',\n","            'Mean_Rank','Convergence_Score']].round(2).to_string())\n","\n","# ── FIG 9: GROUPED BAR — PREVALENCE BY LEVEL ─────────────────────────\n","fig, ax = plt.subplots(figsize=(14, 6))\n","x      = np.arange(len(ARCHETYPE_ORDER))\n","width  = 0.25\n","clevel = {'Macro': '#2c3e50', 'Meso': '#2980b9', 'Micro': '#e74c3c'}\n","\n","for i, (level, col) in enumerate(zip(['Macro','Meso','Micro'],\n","                                      ['Macro_pct','Meso_pct','Micro_pct'])):\n","    vals = conv.reindex(ARCHETYPE_ORDER)[col].fillna(0)\n","    bars = ax.bar(x + (i-1)*width, vals, width,\n","                  label=level, color=clevel[level], alpha=0.85, edgecolor='white')\n","    for bar, v in zip(bars, vals):\n","        if v > 0.5:\n","            ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.3,\n","                    f'{v:.1f}', ha='center', va='bottom', fontsize=7)\n","\n","ax.set_xticks(x)\n","ax.set_xticklabels(ARCHETYPE_ORDER, rotation=30, ha='right', fontsize=10)\n","ax.set_ylabel('% of Level Corpus', fontsize=11)\n","ax.set_title('Fig 9 — Archetype Prevalence Across Three Levels\\n'\n","             'Macro (Ideological Texts) · Meso (Media Events) · Micro (Youth Survey)',\n","             fontsize=13, pad=12)\n","ax.legend(fontsize=10)\n","ax.grid(axis='y', alpha=0.3)\n","plt.tight_layout()\n","plt.savefig(f'{VIZ_DIR}/Fig9_CrossLevel_Prevalence.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","print(\"Fig 9 saved.\")\n","\n","# ── FIG 10: HEATMAP ──────────────────────────────────────────────────\n","heatmap_data = conv.reindex(ARCHETYPE_ORDER)[['Macro_pct','Meso_pct','Micro_pct']].T\n","\n","fig, ax = plt.subplots(figsize=(13, 3.5))\n","sns.heatmap(heatmap_data, annot=True, fmt='.1f', cmap='YlOrRd',\n","            linewidths=0.5, ax=ax, cbar_kws={'label': '% of Level', 'shrink': 0.8})\n","ax.set_title('Fig 10 — Cross-Level Archetype Heatmap (% prevalence)',\n","             fontsize=13, pad=10)\n","ax.set_yticklabels(['Macro (Texts)', 'Meso (Media)', 'Micro (Youth)'],\n","                   rotation=0, fontsize=10)\n","plt.tight_layout()\n","plt.savefig(f'{VIZ_DIR}/Fig10_CrossLevel_Heatmap.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","print(\"Fig 10 saved.\")\n","\n","# ── FINAL SUMMARY ────────────────────────────────────────────────────\n","print(\"\\n\" + \"═\"*72)\n","print(\"NB5-C3-FIX1 COMPLETE — OUTPUT CONFIRMATION\")\n","print(\"═\"*72)\n","print(f\"  [CSV] NB5_archetype_prevalence_by_level.csv  ({all_dist.shape[0]} rows)\")\n","print(f\"  [CSV] NB5_crosslevel_convergence.csv         ({conv.shape[0]} rows)\")\n","print(f\"  [PNG] Fig9_CrossLevel_Prevalence.png\")\n","print(f\"  [PNG] Fig10_CrossLevel_Heatmap.png\")\n","print(\"═\"*72)\n","print(\"\\nTOP 5 CONVERGENT ARCHETYPES (most stable rank across all 3 levels):\")\n","print(conv[['Macro_pct','Meso_pct','Micro_pct','Mean_Rank','Convergence_Score']].head(5).round(2).to_string())\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"wNkTQGLMKbHp","executionInfo":{"status":"ok","timestamp":1771626701500,"user_tz":-60,"elapsed":3095,"user":{"displayName":"Daniel Mejia","userId":"02504160082713739555"}},"