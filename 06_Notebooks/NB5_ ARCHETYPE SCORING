====\n","\n","# Define embedding function (same as NB4)\n","def get_embedding(text):\n","    \"\"\"\n","    Generate normalized embedding using mean pooling + L2 normalization.\n","    \"\"\"\n","    # Truncate very long documents to first 512 tokens (model limit)\n","    inputs = tokenizer(\n","        text,\n","        return_tensors=\"pt\",\n","        truncation=True,\n","        max_length=512,  # Sentence-transformer limit\n","        padding=True\n","    ).to(device)\n","\n","    with torch.no_grad():\n","        outputs = model(**inputs)\n","\n","    # Mean pooling with attention mask\n","    last_hidden_states = outputs.last_hidden_state\n","    attention_mask = inputs['attention_mask']\n","    mask_expanded = attention_mask.unsqueeze(-1).expand(last_hidden_states.size()).float()\n","\n","    sum_embeddings = torch.sum(last_hidden_states * mask_expanded, 1)\n","    sum_mask = torch.clamp(mask_expanded.sum(1), min=1e-9)\n","    mean_pooled = sum_embeddings / sum_mask\n","\n","    # L2 normalization (critical!)\n","    mean_pooled = F.normalize(mean_pooled, p=2, dim=1)\n","\n","    return mean_pooled.cpu().numpy()[0]\n","\n","print(\"=\"*70)\n","print(\"🔄 ENCODING DOCUMENTS & COMPUTING SCORES\")\n","print(\"=\"*70)\n","\n","# Prepare archetype names and vectors\n","archetype_names = list(archetype_prototypes.keys())\n","archetype_matrix = np.stack([archetype_prototypes[name] for name in archetype_names])\n","\n","print(f\"\\nArchetype matrix shape: {archetype_matrix.shape}\")\n","print(f\"Expected: (9, 768)\\n\")\n","\n","# Storage for scores\n","all_scores = []\n","\n","print(f\"⏳ Processing {len(df)} documents...\\n\")\n","\n","for idx, row in tqdm(df.iterrows(), total=len(df), desc=\"Scoring documents\", ncols=80):\n","    doc_id = row['doc_id']\n","    text = row['text']\n","\n","    # Get document embedding\n","    doc_embedding = get_embedding(text)\n","\n","    # Compute cosine similarity with all 9 archetypes\n","    # Since both are normalized, this is just dot product\n","    scores = {}\n","    for i, arch_name in enumerate(archetype_names):\n","        similarity = np.dot(doc_embedding, archetype_matrix[i])\n","        scores[f\"score_{arch_name}\"] = similarity\n","\n","    # Store results\n","    scores['doc_id'] = doc_id\n","    all_scores.append(scores)\n","\n","print(\"\\n✅ All documents scored!\")\n","\n","# Create scores dataframe\n","scores_df = pd.DataFrame(all_scores)\n","\n","# Reorder columns: doc_id first, then archetype scores\n","score_cols = [col for col in scores_df.columns if col.startswith('score_')]\n","scores_df = scores_df[['doc_id'] + score_cols]\n","\n","# Merge with original metadata\n","df_scored = df.merge(scores_df, on='doc_id')\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"📊 SCORING COMPLETE - RESULTS PREVIEW\")\n","print(\"=\"*70)\n","\n","# Show statistics\n","print(f\"\\nScore ranges per archetype:\")\n","for arch in archetype_names:\n","    col = f\"score_{arch}\"\n","    print(f\"  {arch:15} : {df_scored[col].min():.3f} to {df_scored[col].max():.3f}  (mean: {df_scored[col].mean():.3f})\")\n","\n","# Show sample documents\n","print(\"\\n\" + \"=\"*70)\n","print(\"🔍 SAMPLE: Top 3 Documents by Ideology\")\n","print(\"=\"*70)\n","\n","for ideology in df_scored['ideology'].unique():\n","    subset = df_scored[df_scored['ideology'] == ideology].head(1)\n","    if len(subset) > 0:\n","        row = subset.iloc[0]\n","        print(f\"\\n📄 {ideology}: {row['filename'][:50]}...\")\n","        print(f\"   Author: {row['author'][:30]}\")\n","\n","        # Show archetype profile (sorted by score)\n","        arch_scores = {arch: row[f\"score_{arch}\"] for arch in archetype_names}\n","        sorted_archs = sorted(arch_scores.items(), key=lambda x: x[1], reverse=True)\n","\n","        print(\"   Archetype Profile (Top 5):\")\n","        for arch, score in sorted_archs[:5]:\n","            bar = \"█\" * int(score * 50)  # Visual bar\n","            print(f\"      {arch:15} {score:.3f} {bar}\")\n","\n","# Save results\n","print(\"\\n\" + \"=\"*70)\n","print(\"💾 SAVING RESULTS\")\n","print(\"=\"*70)\n","\n","output_file = os.path.join(OUTPUT_PATH, 'macro_archetype_scores.csv')\n","df_scored.to_csv(output_file, index=False, encoding='utf-8')\n","\n","print(f\"✅ Saved full dataset to:\")\n","print(f\"   {output_file}\")\n","print(f\"\\nColumns: {len(df_scored.columns)} ({len(score_cols)} archetype scores + metadata)\")\n","print(f\"Rows: {len(df_scored)}\")\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"✅ NB5 COMPLETE!\")\n","print(\"=\"*70)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LS6TtAFtqgYH","executionInfo":{"status":"ok","timestamp":1770628234224,"user_tz":-60,"elapsed":44142,"user":{"displayName":"Daniel Mejia","userId":"02504160082713739555"}},"outputId":"d102cb30-7e1b-42c0-f24c-c1587847b9e1"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","🔄 ENCODING DOCUMENTS & COMPUTING SCORES\n","======================================================================\n","\n","Archetype matrix shape: (9, 768)\n","Expected: (9, 768)\n","\n","⏳ Processing 38 documents...\n","\n"]},{"output_type":"stream","name":"stderr","text":["Scoring documents: 100%|████████████████████████| 38/38 [00:41<00:00,  1.09s/it]\n"]},{"output_type":"stream","name":"stdout","text":["\n","✅ All documents scored!\n","\n","======================================================================\n","📊 SCORING COMPLETE - RESULTS PREVIEW\n","======================================================================\n","\n","Score ranges per archetype:\n","  Shadow          : 0.150 to 0.508  (mean: 0.322)\n","  Hero            : 0.178 to 0.482  (mean: 0.310)\n","  Wise_Mentor     : 0.171 to 0.453  (mean: 0.290)\n","  Victim          : 0.088 to 0.462  (mean: 0.251)\n","  Trickster       : 0.149 to 0.469  (mean: 0.332)\n","  Great_Mother    : 0.157 to 0.431  (me