e animus turns spirit into shadow, attacking with cold certai...\n","   ✓ Prototype vector: (768,)\n","\n","🔹 Archetype: Self (6 seed phrases)\n","   [1] The Self is wholeness; ego claims it and becomes inflated....\n","   [2] Our movement feels numinous because it mirrors an inner ordering princ...\n","   ✓ Prototype vector: (768,)\n","\n","✅ All 9 prototypes created!\n","\n","======================================================================\n","🔍 PROTOTYPE VALIDATION - Cosine Similarities\n","======================================================================\n","\n","Archetype similarity matrix (should show differentiation):\n","\n","            Shad  Hero  Wise  Vict  Tric  Grea  Anim  Anim  Self\n","Shadow       1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","Hero         1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","Wise_Mentor  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","Victim       1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","Trickster    1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","Great_Mother 1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","Anima        1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","Animus       1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","Self         1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00  1.00\n","\n","📊 Key observations:\n","   - Diagonal: 1.00 (self-similarity)\n","   - Shadow ↔ Victim: 1.00\n","   - Hero ↔ Wise_Mentor: 1.00\n","   - Trickster ↔ Animus: 1.00\n","\n","======================================================================\n","💾 SAVING PROTOTYPES\n","======================================================================\n","✅ Saved 9 archetype prototypes to:\n","   /content/drive/My Drive/MasterThesis_Archetypes/02_Models/archetype_prototypes.pkl\n","   Vector dimensions: 768\n","✅ Similarity matrix saved to:\n","   /content/drive/My Drive/MasterThesis_Archetypes/02_Models/prototype_similarity_matrix.csv\n","\n","======================================================================\n","✅ NB4 COMPLETE - ARCHETYPE PROTOTYPES READY!\n","======================================================================\n"]}],"source":["# ========================================\n","# NB4: Step 3 - Extended Archetype Prototype Creation (9 Archetypes) discarted - deficient results\n","# ========================================\n","\n","import os\n","import torch\n","from transformers import AutoTokenizer, AutoModel\n","import numpy as np\n","import pickle\n","\n","BASE_PATH = '/content/drive/My Drive/MasterThesis_Archetypes'\n","MODELS_PATH = os.path.join(BASE_PATH, '02_Models')\n","\n","print(\"=\"*70)\n","print(\"🧠 LOADING TRANSFORMER MODEL (XLM-RoBERTa-base)\")\n","print(\"=\"*70)\n","\n","MODEL_NAME = \"xlm-roberta-base\"\n","\n","tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n","model = AutoModel.from_pretrained(MODEL_NAME)\n","model.eval()\n","if torch.cuda.is_available():\n","    model.to('cuda')\n","    device = 'cuda'\n","else:\n","    device = 'cpu'\n","\n","print(f\"\\n✅ Loaded {MODEL_NAME} on device: {device}\")\n","\n","# -----------------------------\n","# THEORY-GROUNDED ARCHETYPE SEEDS (Jung + McGovern)\n","# -----------------------------\n","\n","archetype_seeds = {\n","    \"Shadow\": [\n","        \"Our enemy carries the traits we refuse to acknowledge in ourselves.\",\n","        \"What we condemn outside is the unconscious content seeking projection.\",\n","        \"When the crowd gathers, the shadow awakens and demands an outlet.\",\n","        \"Purity talk hides denied impulses; the shadow returns as moral outrage.\",\n","        \"The more righteous we feel, the more darkness we disown.\",\n","        \"If doubt appears, we locate evil in neighbours and rival groups.\",\n","        \"We cannot be wrong; betrayal must be the work of corrupt others.\",\n","        \"Confession is avoided; instead we demand punishment to silence inner conflict.\"\n","    ],\n","\n","    \"Hero\": [\n","        \"I am called to a task larger than my personal comfort.\",\n","        \"The ordeal proves my worth; suffering certifies my exceptional destiny.\",\n","        \"The group needs a champion; I will embody its highest aim.\",\n","        \"Opposition confirms the path; obstacles reveal the sacred mission.\",\n","        \"If I fail, I become the heroic sufferer, still morally superior.\",\n","        \"My cause demands discipline; impulses are subordinated to the goal.\",\n","        \"The myth of renewal requires sacrifice; I accept the burden.\"\n","    ],\n","\n","    \"Wise_Mentor\": [\n","        \"Order precedes freedom; without limits, the psyche collapses into chaos.\",\n","        \"Tradition carries hard-won wisdom; reject it and repeat ancient errors.\",\n","        \"When insight fails, the inner elder speaks through authority and counsel.\",\n","        \"Patience and restraint are virtues; haste invites unconscious possession.\",\n","        \"Sleep on it; clarity emerges when affect yields to reflection.\",\n","        \"The law is symbolic; it binds instinct to shared responsibility.\",\n","        \"The mentor warns of dangers and provides means, not emotional slogans.\"\n","    ],\n","\n","    \"Victim\": [\n","        \"I am misunderstood; the world denies what I deserve by right.\",\n","        \"My suffering proves others are guilty; innocence is measured by pain.\",\n","        \"If I cannot win, I will claim moral purity through injury.\",\n","        \"Responsibility feels like oppression; dependence is recast as virtue.\",\n","        \"The group is wounded; our wounds justify special entitlement and attention.\",\n","        \"We are exposed and persecuted, yet destined to prevail despite all.\",\n","        \"Criticism is harm; disagreement becomes persecution that must be named.\"\n","    ],\n","\n","    \"Trickster\": [\n","        \"He changes shape, speaks in doubles, and undermines stable meaning.\",\n","        \"Rules are mocked; the trickster exposes our blind spots through disruption.\",\n","        \"When nothing works, we blame fate, not our own unconscious errors.\",\n","        \"The trickster creates confusion, then offers salvation as a bargain.\",\n","        \"His mischief mobilizes the collective shadow in crowds and politics.\",\n","        \"He tells half-truths that feel clever, letting conscience fall asleep.\",\n","        \"Language is bent until words mean their opposite, and no one notices.\"\n","    ],\n","\n","    \"Great_Mother\": [\n","        \"The mother shelters life, but demands loyalty as the price of safety.\",\n","        \"Care becomes control when Eros turns into unconscious will to power.\",\n","        \"She lives through others; without them, her identity feels empty.\",\n","        \"To protect the child, she may annihilate the child's independent personality.\",\n","        \"The Great Mother holds opposites: blessing and curse in one figure.\",\n","        \"If love is lacking, maternal devotion hardens into fanatical rights.\"\n","    ],\n","\n","    \"Anima\": [\n","        \"The anima fascinates the ego, making feeling seem like absolute truth.\",\n","        \"She appears youthful, alluring, and demands devotion beyond rational limits.\",\n","        \"Unintegrated longing is projected onto ideals, movements, or distant figures.\",\n","        \"When relationship fails, the anima turns critical and poisons perception.\",\n","        \"Behind the shadow stands fascination; the inner feminine captivates and compels.\"\n","    ],\n","\n","    \"Animus\": [\n","        \"The animus speaks in rigid convictions, presenting opinion as pure reason.\",\n","        \"A negative animus turns spirit into shadow, attacking with cold certainty.\",\n","        \"He demands ideological consistency and ignores lived experience and nuance.\",\n","        \"When the ego is weak, the animus takes over as a chorus.\",\n","        \"The positive animus supports conscious effort and disciplined spiritual striving.\"\n","    ],\n","\n","    \"Self\": [\n","        \"The Self is wholeness; ego claims it and becomes inflated.\",\n","        \"Our movement feels numinous because it mirrors an inner ordering principle.\",\n","        \"Individuation requires integrating opposites, not abolishing the dark half.\",\n","        \"When the center shifts from ego to Self, meaning reorganizes life.\",\n","        \"The promise of total renewal hides the demand for inner synthesis.\",\n","        \"The sacred symbol is a vessel; we fill it with our own projections.\"\n","    ]\n","}\n","\n","print(f\"\\n✅ Defined {len(archetype_seeds)} archetypes:\")\n","for name in archetype_seeds.keys():\n","    print(f\"   • {name}\")\n","\n","# -----------------------------\n","# Helper: embed a sentence\n","# -----------------------------\n","\n","def encode_text(text: str) -> np.ndarray:\n","    \"\"\"\n","    Encode a single text into a 768-d embedding using mean pooling.\n","    \"\"\"\n","    with torch.no_grad():\n","        inputs = tokenizer(\n","            text,\n","            return_tensors=\"pt\",\n","            truncation=True,\n","            max_length=256,\n","            padding=\"max_length\"\n","        )\n","        inputs = {k: v.to(device) for k, v in inputs.items()}\n","        outputs = model(**inputs)\n","        # Mean pooling over sequence length\n","        last_hidden = outputs.last_hidden_state  # [1, seq_len, hidden]\n","        mask = inputs['attention_mask'].unsqueeze(-1)  # [1, seq_len, 1]\n","        masked_embeddings = last_hidden * mask\n","        summed = masked_embeddings.sum(dim=1)\n","        counts = mask.sum(dim=1).clamp(min=1)\n","        mean_pooled = (summed / counts).squeeze(0)\n","        return mean_pooled.cpu().numpy()\n","\n","# -----------------------------\n","# Build prototypes\n","# -----------------------------\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"📐 BUILDING 9 ARCHETYPE PROTOTYPES\")\n","print(\"=\"*70)\n","\n","archetype_prototypes = {}\n","\n","for name, phrases in archetype_seeds.items():\n","    print(f\"\\n🔹 Archetype: {name} ({len(phrases)} seed phrases)\")\n","    emb_list = []\n","    for i, sent in enumerate(phrases, 1):\n","        emb = encode_text(sent)\n","        emb_list.append(emb)\n","        # Show first 2 seeds for verification\n","        if i <= 2:\n","            print(f\"   [{i}] {sent[:70]}...\")\n","    # Average embeddings\n","    proto_vec = np.mean(np.stack(emb_list, axis=0), axis=0)\n","    archetype_prototypes[name] = proto_vec\n","    print(f\"   ✓ Prototype vector: {proto_vec.shape}\")\n","\n","print(\"\\n✅ All 9 prototypes created!\")\n","\n","# -----------------------------\n","# Validation: Inter-prototype distances\n","# -----------------------------\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"🔍 PROTOTYPE VALIDATION - Cosine Similarities\")\n","print(\"=\"*70)\n","\n","from sklearn.metrics.pairwise import cosine_similarity\n","\n","proto_names = list(archetype_prototypes.keys())\n","proto_matrix = np.stack([archetype_prototypes[name] for name in proto_names])\n","sim_matrix = cosine_similarity(proto_matrix)\n","\n","print(\"\\nArchetype similarity matrix (should show differentiation):\\n\")\n","print(\"           \", \"  \".join([f\"{n[:4]:>4}\" for n in proto_names]))\n","for i, name in enumerate(proto_names):\n","    row_str = f\"{name[:12]:12} \" + \"  \".join([f\"{sim_matrix[i,j]:4.2f}\" for j in range(len(proto_names))])\n","    print(row_str)\n","\n","print(\"\\n📊 Key observations:\")\n","print(f\"   - Diagonal: 1.00 (self-similarity)\")\n","print(f\"   - Shadow ↔ Victim: {sim_matrix[0, 3]:.2f}\")\n","print(f\"   - Hero ↔ Wise_Mentor: {sim_matrix[1, 2]:.2f}\")\n","print(f\"   - Trickster ↔ Animus: {sim_matrix[4, 7]:.2f}\")\n","\n","# -----------------------------\n","# Save prototypes\n","# -----------------------------\n","\n","proto_file = os.path.join(MODELS_PATH, 'archetype_pr