 OK\")\n","except ImportError as e:\n","    print(\"❌ scikit-learn import failed:\", e)\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"✅ NB4 ENVIRONMENT READY!\")\n","print(\"=\"*70)\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"i7FD1zPlPfxt","executionInfo":{"status":"ok","timestamp":1770624984454,"user_tz":-60,"elapsed":215316,"user":{"displayName":"Daniel Mejia","userId":"02504160082713739555"}},"outputId":"d848a009-95d6-41c5-bd8c-34149682b7d5"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","📚 WORD2VEC TRAINING - DOMAIN-SPECIFIC EMBEDDINGS\n","======================================================================\n","\n","✅ Loaded 38 documents\n","\n","🔄 Tokenizing texts into sentences...\n"]},{"output_type":"stream","name":"stderr","text":["Tokenizing documents: 100%|███████████| 38/38 [00:23<00:00,  1.62it/s]\n"]},{"output_type":"stream","name":"stdout","text":["\n","✅ Prepared 215,272 sentences for training\n","   Sample sentence: ['but', 'the', 'leading', 'institutions', 'of', 'man', 'enslavement', 'my', 'two', 'betes']...\n","\n","======================================================================\n","🤖 TRAINING WORD2VEC MODEL\n","======================================================================\n","\n","Hyperparameters:\n","  - Architecture: Skip-gram (sg=1)\n","  - Vector size: 300 dimensions\n","  - Context window: 5 words\n","  - Min word frequency: 5 occurrences\n","  - Epochs: 5\n","  - Workers: 4 (parallel)\n","\n","⏳ Training started (this may take 2-5 minutes)...\n","\n","✅ Training complete!\n","\n","📊 Model Statistics:\n","   Vocabulary size: 42,404 unique words\n","   Vector dimensions: 300\n","   Total training sentences: 215,272\n","\n","======================================================================\n","🧪 MODEL QUALITY CHECK - Semantic Similarity Tests\n","======================================================================\n","\n","Semantic similarities:\n","   communist ↔ communism: 0.589\n","   freedom ↔ liberty: 0.640\n","   enemy ↔ threat: 0.590\n","   revolution ↔ revolt: 0.541\n","   nation ↔ country: 0.735\n","\n","🔍 Most similar words to 'power':\n","   conquestof: 0.637\n","   thepower: 0.634\n","   seizure: 0.619\n","   purchasing: 0.610\n","   strength: 0.610\n","\n","======================================================================\n","💾 SAVING MODEL\n","======================================================================\n","✅ Model saved to:\n","   /content/drive/My Drive/MasterThesis_Archetypes/02_Models/word2vec_domain_specific.model\n","   Size: 1.4 MB\n","\n","======================================================================\n","✅ WORD2VEC TRAINING COMPLETE!\n","======================================================================\n"]}],"source":["# ========================================\n","# NB4: Step 2 - Train Word2Vec Model\n","# ========================================\n","\n","import pandas as pd\n","import os\n","from gensim.models import Word2Vec\n","from gensim.utils import simple_preprocess\n","from tqdm import tqdm\n","import warnings\n","warnings.filterwarnings('ignore')\n","\n","# Paths\n","BASE_PATH = '/content/drive/My Drive/MasterThesis_Archetypes'\n","CORPUS_PATH = os.path.join(BASE_PATH, '01_ProcessedCorpora/macro_corpus_clean.csv')\n","MODELS_PATH = os.path.join(BASE_PATH, '02_Models')\n","\n","print(\"=\"*70)\n","print(\"📚 WORD2VEC TRAINING - DOMAIN-SPECIFIC EMBEDDINGS\")\n","print(\"=\"*70)\n","\n","# Load corpus\n","df = pd.read_csv(CORPUS_PATH, encoding='utf-8')\n","print(f\"\\n✅ Loaded {len(df)} documents\")\n","\n","# Prepare training data\n","print(\"\\n🔄 Tokenizing texts into sentences...\")\n","\n","def tokenize_for_word2vec(text):\n","    \"\"\"\n","    Convert text into list of tokenized sentences\n","    \"\"\"\n","    if not isinstance(text, str):\n","        return []\n","\n","    # Split into sentences (simple approach)\n","    sentences = text.split('.')\n","\n","    # Tokenize each sentence\n","    tokenized_sentences = []\n","    for sent in sentences:\n","        # simple_preprocess: lowercase + remove punctuation + min length\n","        tokens = simple_preprocess(sent, deacc=True, min_len=2, max_len=50)\n","        if len(tokens) >= 3:  # Keep sentences with at least 3 words\n","            tokenized_sentences.append(tokens)\n","\n","    return tokenized_sentences\n","\n","# Tokenize all documents\n","all_sentences = []\n","for text in tqdm(df['text'], desc=\"Tokenizing documents\", ncols=70):\n","    all_sentences.extend(tokenize_for_word2vec(text))\n","\n","print(f\"\\n✅ Prepared {len(all_sentences):,} sentences for training\")\n","print(f\"   Sample sentence: {all_sentences[100][:10]}...\")\n","\n","# Train Word2Vec\n","print(\"\\n\" + \"=\"*70)\n","print(\"🤖 TRAINING WORD2VEC MODEL\")\n","print(\"=\"*70)\n","\n","print(\"\\nHyperparameters:\")\n","print(\"  - Architecture: Skip-gram (sg=1)\")\n","print(\"  - Vector size: 300 dimensions\")\n","print(\"  - Context window: 5 words\")\n","print(\"  - Min word frequency: 5 occurrences\")\n","print(\"  - Epochs: 5\")\n","print(\"  - Workers: 4 (parallel)\")\n","\n","print(\"\\n⏳ Training started (this may take 2-5 minutes)...\\n\")\n","\n","model = Word2Vec(\n","    sentences=all_sentences,\n","    vector_size=300,        # 300-dimensional embeddings\n","    window=5,                # Context window of 5 words\n","    min_count=5,            # Ignore words that appear < 5 times\n","    sg=1,                   # Skip-gram (1) vs CBOW (0)\n","    epochs=5,               # Training iterations\n","    workers=4,              # Parallel processing\n","    seed=42                 # Reproducibility\n",")\n","\n","print(\"✅ Training complete!\")\n","\n","# Model statistics\n","vocab_size = len(model.wv)\n","print(f\"\\n📊 Model Statistics:\")\n","print(f\"   Vocabulary size: {vocab_size:,} unique words\")\n","print(f\"   Vector dimensions: {model.wv.vector_size}\")\n","print(f\"   Total training sentences: {len(all_sentences):,}\")\n","\n","# Test the model with sample queries\n","print(\"\\n\" + \"=\"*70)\n","print(\"🧪 MODEL QUALITY CHECK - Semantic Similarity Tests\")\n","print(\"=\"*70)\n","\n","test_words = [\n","    ('communist', 'communism'),\n","    ('freedom', 'liberty'),\n","    ('enemy', 'threat'),\n","    ('revolution', 'revolt'),\n","    ('nation', 'country')\n","]\n","\n","print(\"\\nSemantic similarities:\")\n","for word1, word2 in test_words:\n","    if word1 in model.wv and word2 in model.wv:\n","        similarity = model.wv.similarity(word1, word2)\n","        print(f\"   {word1} ↔ {word2}: {similarity:.3f}\")\n","    else:\n","        missing = word1 if word1 not in model.wv else word2\n","        print(f\"   {word1} ↔ {word2}: ('{missing}' not in vocabulary)\")\n","\n","# Find similar words\n","print(\"\\n🔍 Most similar words to 'power':\")\n","if 'power' in model.wv:\n","    similar = model.wv.most_similar('power', topn=5)\n","    for word, score in similar:\n","        print(f\"   {word}: {score:.3f}\")\n","\n","# Save model\n","print(\"\\n\" + \"=\"*70)\n","print(\"💾 SAVING MODEL\")\n","print(\"=\"*70)\n","\n","model_file = os.path.join(MODELS_PATH, 'word2vec_domain_specific.model')\n","model.save(model_file)\n","\n","print(f\"✅ Model saved to:\")\n","print(f\"   {model_file}\")\n","print(f\"   Size: {os.path.getsize(model_file) / (1024*1024):.1f} MB\")\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"✅ WORD2VEC TRAINING COMPLETE!\")\n","print(\"=\"*70)\n"]},{"cell_type":"code","source":["# ========================================\n","# NB4: Step 3 - FIXED Archetype Prototype Creation - Best results\n","# ========================================\n","\n","import os\n","import torch\n","import torch.nn.functional as F\n","from transformers import AutoTokenizer, AutoModel\n","import numpy as np\n","import pickle\n","import pandas as pd\n","from sklearn.metrics.pairwise import cosine_similarity\n","\n","# 1. SETUP & MODEL LOADING\n","# -----------------------------\n","BASE_PATH = '/content/drive/My Drive/MasterThesis_Archetypes'\n","MODELS_PATH = os.path.join(BASE_PATH, '02_Models')\n","# We use the SBERT version of XLM-R to fix the anisotropy (cone) problem\n","MODEL_NAME = \"sentence-transformers/paraphrase-xlm-r-multilingual-v1\"\n","\n","print(\"=\"*70)\n","print(f\"🧠 LOADING TRANSFORMER MODEL ({MODEL_NAME})\")\n","print(\"=\"*70)\n","\n","tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n","model = AutoModel.from_pretrained(MODEL_NAME)\n","model.eval()\n","\n","if torch.cuda.is_available():\n","    model.to('cuda')\n","    print(\"✅ Model loaded on GPU (CUDA)\")\n","else:\n","    print(\"⚠️ GPU not detected. Running on CPU (slower).\")\n","\n","# 2. DEFINING \"HYBRID\" SEEDS (Keywords + Context)\n","# -----------------------------\n","# Strategy: We mix strong, punchy keywords (for direction) with\n","# Jungian sentences (for context). This fixes the \"blurring\" effect.\n","\n","archetype_seeds = {\n","    \"Shadow\": [\n","        \"Traitor, enemy, darkness, evil, repress, hate, scum, vermin.\",\n","        \"Our enemy carries the traits we refuse to acknowledge in ourselves.\",\n","        \"They are corrupt, dirty, and dangerous to our pure society.\",\n","        \"What we condemn in them is actually our own hidden darkness.\",\n","        \"Betrayal, conspiracy, lies, poison, destroy, kill.\"\n","    ],\n","\n","    \"Hero\": [\n","        \"Glory, honor, save, fight, victory, sacrifice, brave, destiny.\",\n","        \"I am called to a task larger than my personal comfort.\",\n","        \"We must fight to save our people from the coming danger.\",\n","        \"The ordeal proves my worth; suffering certifies my exceptional destiny.\",\n","        \"Warrior, champion, strength, courage, win, triumph.\"\n","    ],\n","\n","    \"Wise_Mentor\": [\n","        \"Law, order, rule, obey, discipline, control, stable, wisdom.\",\n","        \"Order precedes freedom; without limits, the psyche collapses into chaos.\",\n","        \"We need structure and tradition to survive this storm.\",\n","        \"Tradition carries hard-won wisdom; reject it and repeat ancient errors.\",\n","        \"Authority, guidance, elder, teach, truth, hierarchy.\"\n","    ],\n","\n","    \"Victim\": [\n","        \"Suffer, pain, innocent, hurt, wound, unfair, blame, help.\",\n","        \"I am misunderstood; the world denies what I deserve by right.\",\n","        \"Look at how they hurt us; we are the innocent ones here.\",\n","        \"My suffering proves others are guilty; innocence is measured by pain.\",\n","        \"Abuse, tears, weak, damaged, helpless, pity.\"\n","    ],\n","\n","    \"Trickster\": [\n","        \"Chaos, joke, mask, laugh, disrupt, fool, change, lie.\",\n","        \"He changes shape, speaks in doubles, and undermines stable meaning.\",\n","        \"Nothing is true; everything is a game to be played.\",\n","        \"Rules are mocked; the trickster exposes our blind spots through disruption.\",\n","        \"Prank, absurd, twist, mockery, irony, fake.\"\n","    ],\n","\n","    \"Great_Mother\": [\n","        \"Mother, care, womb, home, safety, feed, protect, love.\",\n","        \"The mother shelters life, but demands loyalty as the price of safety.\",\n","        \"Come back to the earth, to the family, to the warm embrace.\",\n","        \"Care becomes control when Eros turns into unconscious will to power.\",\n","        \"Nurture, smother, earth, birth, warmth, family.\"\n","    ],\n","\n","    \"Anima\": [\n","        \"Love, desire, dream, beauty, soul, emotion, fantasy, lure.\",\n","        \"The anima fascinates the ego, making feeling seem like absolute truth.\",\n","        \"She is the muse that leads us into the unknown depths.\",\n","        \"Unintegrated longing is projected onto ideals or distant figures.\",\n","        \"Passion, mood, irrational, feeling, heart, romance.\"\n","    ],\n","\n","    \"Animus\": [\n","        \"Logic, mind, sword, rigid, fact, judge, opinion, hard.\",\n","        \"The animus speaks in rigid convictions, presenting opinion as pure reason.\",\n","        \"It is objectively true; there is no room for argument.\",\n","        \"A negative animus turns spirit into shadow, attacking with cold certainty.\",\n","        \"Intellect, principle, argument, convince, rational, dry.\"\n","    ],\n","\n","    \"Self\": [\n","        \"Whole, center, god, spirit, one, balance, mandala, peace.\",\n","        \"The Self is wholeness; the union of light and dark.\",\n","        \"Our movement feels numinous because it mirrors an inner ordering principle.\",\n","        \"Individuation requires integrating opposites, not abolishing the dark half.\",\n","        \"Unity, synthesis, divine, complete, core, soul.\"\n","    ]\n","}\n","\n","print(f\"\\n✅ Defined {len(archetype_seeds)} archetypes with Hybrid Seeds.\")\n","\n","# 3. THE FIXED EMBEDDING FUNCTION\n","# -----------------------------\n","def get_embedding(text):\n","    \"\"\"\n","    Generates a normalized embedding using Mean Pooling of the Last Hidden State.\n","    Crucial: Includes F.normalize to fix the 'Cone Effect'.\n","    \"\"\"\n","    inputs = tokenizer(text, return_tensors=\"pt\", truncation=True, max_length=256, padding=True).to(model.device)\n","\n","    with torch.no_grad():\n","        outputs = model(**inputs)\n","\n","    # Get last hidden states\n","    last_hidden_states = outputs.last_hidden_state\n","\n","    # Create attention mask\n","    attention_mask = inputs['attention_mask']\n","    mask_expanded = attention_mask.unsqueeze(-1).expand(last_hidden_states.size()).float()\n","\n","    # Mean Pooling\n","    sum_embeddings = torch.sum(last_hidden_states * mask_expanded, 1)\n","    sum_mask = torch.clamp(mask_expanded.sum(1), min=1e-9)\n","    mean_pooled = sum_embeddings / sum_mask\n","\n","    # NORMALIZATION (The Fix!)\n","    # This forces vectors onto the hypersphere, making Cosine Similarity valid.\n","    mean_pooled = F.normalize(mean_pooled, p=2, dim=1)\n","\n","    return mean_pooled.cpu().numpy()[0]\n","\n","# 4. BUILD PROTOTYPES\n","# -----------------------------\n","print(\"\\n\" + \"=\"*70)\n","print(\"📐 BUILDING PROTOTYPES\")\n","print(\"=\"*70)\n","\n","archetype_prototypes = {}\n","\n","for name, seeds in archetype_seeds.items():\n","    print(f\"🔹 Processing: {name}...\")\n","    vectors = []\n","    for seed in seeds:\n","        vec = get_embedding(seed)\n","        vectors.append(vec)\n","\n","    # Average the vectors to create the Prototype\n","    # We re-normalize the final prototype to keep it unit length\n","    avg_vector = np.mean(vectors, axis=0)\n","    avg_vector = avg_vector / np.linalg.norm(avg_vector)\n","\n","    archetype_prototypes[name] = avg_vector\n","\n","print(\"✅ All prototypes built.\")\n","\n","# 5. VALIDATION MATRIX\n","# -----------------------------\n","print(\"\\n\" + \"=\"*70)\n","print(\"🔍 VALIDATION: SIMILARITY MATRIX\")\n","print(\"=\"*70)\n","\n","names = list(archetype_prototypes.keys())\n","matrix = np.zeros((len(names), len(names)))\n","\n","for i, name_a in enumerate(names):\n","    for j, name_b in enumerate(names):\n","        # Manual Cosine Similarity: (A . B) / (|A|*|B|)\n","        # Since we normalized, |A| and |B| are 1.0, so just dot product works.\n","        score = np.dot(archetype_prototypes[name_a], archetype_prototypes[name_b])\n","        matrix[i, j] = score\n","\n","# Print readable table\n","print(f\"{'':12}\", end=\"\")\n","for n in names:\n","    print(f\"{n[:4]:>6}\", end=\"\")\n","print()\n","\n","for i, row_name in enumerate(names):\n","    print(f\"{row_name:12}\", end=\"\")\n","    for val in matrix[i]:\n","        # Color coding for readability\n","        if val > 0.85 and val < 0.99:\n","            print(f\"\\033[91m{val:>6.2f}\\033[0m\", end=\"\") # Red if too high\n","        elif val < 0.6:\n","            print(f\"\\033[92m{val:>6.2f}\\033[0m\", end=\"\") # Green if distinct\n","        else:\n","            print(f\"{val:>6.2f}\", end=\"\")\n","    print()\n","\n","print(\"\\n(Target: Values between different archetypes should be < 0.85)\")\n","\n","# 6. SAVE\n","# -----------------------------\n","proto_file = os.path.join(MODELS_PATH, 'archetype_prototypes.pkl')\n","with open(proto_file, 'wb') as f:\n","    pickle.dump(archetype_prototypes, f)\n","\n","print(f\"\\n💾 Saved prototypes to: {proto_file}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":830,"referenced_widgets":["47a79d65b7784e61ae8166ec7a838bea","72919bb0b61c4a53933b2996d21921d5","70bcd2c0060b406ea69ab3ce3d28cd7a","411446c49fce47029519753cc6521933","43a732929e534db5b6dff49ecea85c5f","522990ea535741ab8865de454464e23b","57fbf017109649ee937187624c2d4303","cf4ec3758cf34bd189cdcb92e69f318d","78e6ac8ff7a74f27bf1a35d7f150028c","f74459a76a6e46858825cb23c8bf3ffa","40a9a24089424020ad992723136b6446"]},"id":"_606-SuRdmHj","executionInfo":{"status":"ok","timestamp":1770626633101,"user_tz":-60,"elapsed":5970,"user":{"displayName":"Daniel Mejia","userId":"02504160082713739555"}},"outputId":"2b6857dd-79d0-4d69-b20d-3a81535c5986"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","🧠 LOADING TRANSFORMER MODEL (sentence-transformers/paraphrase-xlm-r-multilingual-v1)\n","======================================================================\n"]},{"output_type":"display_data","data":{"text/plain":["Loading weights:   0%|          | 0/199 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"47a79d65b7784e61ae8166ec7a838bea"}},"metadata":{}},{"output_type":"stream","name":"stderr","text":["XLMRobertaModel LOAD REPORT from: sentence-transformers/paraphrase-xlm-r-multilingual-v1\n","Key   