"\\nMean Archetype Scores by Ideology:\\n\")\n","print(ideology_means.round(3))\n","\n","# Save table\n","ideology_means.to_csv(os.path.join(OUTPUT_PATH, 'ideology_archetype_means.csv'))\n","print(f\"\\n💾 Saved to: ideology_archetype_means.csv\")\n","\n","# ========================================\n","# ANALYSIS 2: ANOVA (Do ideologies differ?)\n","# ========================================\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"📊 ANALYSIS 2: ANOVA - IDEOLOGY DIFFERENCES\")\n","print(\"=\"*70)\n","\n","anova_results = []\n","\n","for arch_col, arch_name in zip(arch_cols, arch_names):\n","    groups = [df[df['ideology'] == ideology][arch_col].values\n","              for ideology in df['ideology'].unique()]\n","\n","    f_stat, p_value = stats.f_oneway(*groups)\n","\n","    anova_results.append({\n","        'Archetype': arch_name,\n","        'F_statistic': f_stat,\n","        'p_value': p_value,\n","        'Significant': '✓' if p_value < 0.05 else '✗'\n","    })\n","\n","anova_df = pd.DataFrame(anova_results).sort_values('p_value')\n","print(\"\\nANOVA Results (sorted by p-value):\\n\")\n","print(anova_df.to_string(index=False))\n","\n","anova_df.to_csv(os.path.join(OUTPUT_PATH, 'anova_results.csv'), index=False)\n","print(f\"\\n💾 Saved to: anova_results.csv\")\n","\n","# ========================================\n","# ANALYSIS 3: Correlation Matrix\n","# ========================================\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"📊 ANALYSIS 3: ARCHETYPE CORRELATION MATRIX\")\n","print(\"=\"*70)\n","\n","corr_matrix = df[arch_cols].corr()\n","corr_matrix.columns = arch_names\n","corr_matrix.index = arch_names\n","\n","print(\"\\nArchetype Correlations:\\n\")\n","print(corr_matrix.round(2))\n","\n","corr_matrix.to_csv(os.path.join(OUTPUT_PATH, 'archetype_correlations.csv'))\n","print(f\"\\n💾 Saved to: archetype_correlations.csv\")\n","\n","# ========================================\n","# VISUALIZATION 1: Ideology × Archetype Heatmap\n","# ========